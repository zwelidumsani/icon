	<!-- Faq Form Section -->
	<section class="faq-form-section" style="background-image:url(images/background/11.jpg)">
		<div class="auto-container">
			<!-- Sec Title -->
			<div class="sec-title light">
				<div class="title-inner">
					<div class="title">Ask A Question</div>
					<h2>Contact Us</h2>
				</div>
			</div>
			
			<!-- Faq Form -->
			<div class="faq-form">
				     {{#if FaqEmailSuccess}} 
						 <div class = "alert alert-success" alert-dismissable style = "border-radius:10px;>
							 <p class= "pull-right"><button type = "button" class = "close" data-dismiss = "alert" aria-hidden = "true"><i class = "lnr lnr-cross-circle"></i></button>
							 <i class = "lnr lnr-checkmark-circle"></i>  Email address was successfully sent.</p>
						 </div>	
			            {{/if}}
			   
				        {{#if FaqEmailError}} 
						 <div class = "alert alert-danger" alert-dismissable style = "border-radius:10px;>
							 <p class= "pull-right"><button type = "button" class = "close" data-dismiss = "alert" aria-hidden = "true"><i class = "lnr lnr-cross-circle"></i></button>
							 <i class = "lnr lnr-cross-circle"></i>  Could not send email.</p>
						 </div>	
				        {{/if}}	
				<!--Contact Form-->
				<form method="post" action="/email">
					<div class="row clearfix">
					
						<div class="form-group col-lg-6 col-md-6 col-sm-12">
							<input type="text" name="name" placeholder="Name" required>
						</div>
						
						<div class="form-group col-lg-6 col-md-6 col-sm-12">
							<input type="text" name="email" placeholder="Email" required>
						</div>
						
						<div class="form-group col-lg-6 col-md-6 col-sm-12">
							<input type="text" name="phone" placeholder="Phone" required>
						</div>
						
						<div class="form-group col-lg-6 col-md-6 col-sm-12">
							<input type="text" name="subject" placeholder="Subject" required>
						</div>
						
						<div class="form-group col-lg-12 col-md-12 col-sm-12">
							<textarea name="message" placeholder="Question Detail"></textarea>
						</div>
						
						<div class="form-group col-lg-12 col-md-12 col-sm-12">
							<button class="theme-btn btn-style-two" type="submit" name="submit-form">Get A Quote</button>
						</div>
						
					</div>
				</form>
			</div>
			
		</div>	
	</section>
	<!-- End Faq Form Section -->
	
